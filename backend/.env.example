# ═══════════════════════════════════════════════════════════════════
# OmniID GDPR — Environment Variables Template
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════════

# ─── Server Configuration ────────────────────────────────────────
PORT=3000
HTTPS_PORT=3443
ENABLE_HTTPS=false
NODE_ENV=development

# ─── Encryption (MANDATORY for GDPR compliance) ──────────────────
# Local Fallback Master Key (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
OMNIID_MASTER_ENCRYPTION_KEY=
OMNIID_KEY_VERSION=1

# ─── Enterprise KMS: HashiCorp Vault ─────────────────────────────
# If Vault is configured, the local master key above is ignored.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=your-vault-root-or-app-token
VAULT_TRANSIT_KEY=omniid-gdpr-key

# ─── JWT Session Management ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
OMNIID_JWT_SECRET=

# ─── TLS Certificates (production only) ──────────────────────────
TLS_CERT_PATH=
TLS_KEY_PATH=
TLS_CA_PATH=
ENABLE_MTLS=false

# ─── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ─── WebAuthn ─────────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=OmniID Sovereign Identity

# ─── Privacy & GDPR ──────────────────────────────────────────────
PRIVACY_POLICY_VERSION=1.0
DATA_CONTROLLER_EMAIL=controller@omniid.gov
DPO_EMAIL=dpo@omniid.gov
OMNIID_IP_SALT=change-this-to-a-random-value

# ─── Email (for erasure confirmations) ────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@omniid.gov
